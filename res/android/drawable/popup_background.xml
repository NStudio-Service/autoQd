<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
	<!-- 第一层阴影 -->
	<item>
		<shape>
			<solid android:color="#005B0C"/>
			<corners
					android:bottomLeftRadius="5dp" android:bottomRightRadius="5dp" android:topRightRadius="5dp" android:topLeftRadius="5dp"/>
			/>
		</shape>
	</item>
	<!--第二层前景 底偏移1dp -->
	<item android:bottom="2dp">
		<shape>
			<solid android:color="@android:color/white"/>
			<stroke
					android:width="1dp" android:color="#005B0C"/>
			<corners
					android:bottomLeftRadius="5dp" android:bottomRightRadius="5dp" android:topRightRadius="5dp" android:topLeftRadius="5dp"/>
		</shape>
	</item>
</layer-list>